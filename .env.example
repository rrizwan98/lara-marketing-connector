# Copy to .env and adjust. v0.1 defaults run a public/demo server with no sign-in.

# ---- v0.1 PUBLIC / DEMO (defaults) ----
AUTH_DISABLED=1                 # no sign-in; fixed public identity
GATING_ENABLED=false            # everyone gets full access (no tier limits yet)
PUBLIC_TIER=max                 # tier reported while gating is off
SESSION_SIGNING_SECRET=         # set a strong random 32+ byte value before going public

# ---- server ----
HOST=127.0.0.1
PORT=8000
LARA_TRANSPORT=http             # FastMCP streamable HTTP, served at /mcp
LARA_DB_PATH=                   # default: ./lara.db
LARA_SKILLS_DIR=                # default: ./skills

# ---- FUTURE: subscriptions on ----
# GATING_ENABLED=true

# ---- FUTURE: production OAuth (AUTH_DISABLED=0) ----
# AUTH_DISABLED=0
# AUTH_ISSUER=https://your-idp.example.com/
# AUTH_AUDIENCE=lara-marketing-connector
# AUTH_JWKS_URL=https://your-idp.example.com/.well-known/jwks.json
# RESOURCE_URL=https://your-public-host/mcp
